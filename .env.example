# =====================================================
# FIREBASE CONFIG — Copy file này thành .env và điền vào
# =====================================================
# Bước 1: Vào https://console.firebase.google.com/
# Bước 2: Tạo project → Build → Realtime Database → Create Database
#         Chọn "Start in test mode" (cho phép read/write)
# Bước 3: Project Settings > General > Your Apps > Web > Config
# Bước 4: Copy từng giá trị vào đây

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.asia-southeast1.firebasedatabase.app
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
